APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=programming_problems

EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RETRIEVAL_LANGUAGE=zh-Hant

# OAuth-capable provider adapter settings. The core app must also run without
# these values by using the mock/no-LLM provider.
LLM_PROVIDER=mock
LLM_OAUTH_ISSUER=
LLM_OAUTH_CLIENT_ID=
LLM_OAUTH_CLIENT_SECRET=
